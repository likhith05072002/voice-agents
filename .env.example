# ─── Sarvam AI (required) ───
SARVAM_API_KEY=your-sarvam-key

# ─── Telephony: Telnyx ───
TELNYX_API_KEY=your-telnyx-key
# Base HTTPS URL where this server is reachable (used to build the wss media URL).
PUBLIC_URL=https://your-host.example.com
# Telnyx webhook signing public key (base64 Ed25519). When set, webhooks are
# verified and rejected on a bad signature. Leave blank only for local dev.
TELNYX_PUBLIC_KEY=

# ─── Telephony: EnableX (optional, India) ───
ENABLEX_APP_ID=
ENABLEX_APP_KEY=

# ─── Models / language ───
DEFAULT_LANGUAGE=te-IN
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_VOICE=anushka
SARVAM_LLM_MODEL=sarvam-30b

# ─── Turn engine tunables ───
ENABLE_FILLERS=false
STT_BUFFER_MS=100

# ─── Server ───
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=debug

# Optional LLM fallbacks (unused by default)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
